#: ../../functions/func_delprefix.rst:6
msgid "$delprefix"
msgstr "$delprefix"

#: ../../functions/func_delprefix.rst:8
msgid "Usage: **$delprefix(text[,prefixes])**"
msgstr "Gebruik: **$delprefix(tekst[,prefixen])**"

#: ../../functions/func_delprefix.rst:9
msgid "Category: text"
msgstr "Categorie: tekst"

#: ../../functions/func_delprefix.rst:10
msgid "Implemented: Picard 1.3"
msgstr "Geïmplementeerd: Picard 1.3"

#: ../../functions/func_delprefix.rst:12
msgid "**Description:**"
msgstr "**Beschrijving:**"

#: ../../functions/func_delprefix.rst:14
msgid ""
"Deletes the specified ``prefixes`` from the beginning of ``text``. Any "
"number of ``prefixes`` can be specified, separated by commas. If no prefix "
"is specified \"A\" and \"The\" are used by default. Note that the matching "
"is case-sensitive."
msgstr ""
"Verwijdert de opgegeven ``prefixen`` van het begin van ``tekst``. Je kan elk "
"aantal ``prefixen`` opgeven, gescheiden door komma’s. Als er geen prefix "
"wordt opgegeven, worden standaard ‘A’ en ‘The’ gebruikt. Let op: de prefixen "
"zijn hoofdlettergevoelig."

